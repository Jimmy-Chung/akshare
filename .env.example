# Longbridge / 长桥 OpenAPI
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# OAuth（固定 API 凭证为空时启用）
# 云端建议显式配置；不填 CLIENT_ID 时后端会首次登录时自动注册
LONGBRIDGE_OAUTH_CLIENT_ID=
LONGBRIDGE_OAUTH_REDIRECT_URI=http://localhost:3005/api/auth/longbridge/callback
LONGBRIDGE_OAUTH_CLIENT_NAME=Finogeeks Market Terminal
LONGBRIDGE_OAUTH_AUTO_REGISTER=true
# 中国大陆部署可设为 cn
LONGBRIDGE_REGION=cn

# 云端必须改为实际 HTTPS 域名，并设置稳定的随机密钥
PUBLIC_APP_URL=http://localhost:3005
PUBLIC_API_URL=http://localhost:5001
FLASK_SECRET_KEY=replace-with-a-long-random-value
# PUBLIC_APP_URL 为 HTTPS 时会自动启用；也可显式设置 true/false
SESSION_COOKIE_SECURE=

# 网页访问凭证（使用 ./start.sh configure-access 生成，不要手工填写明文）
DASHBOARD_ACCESS_PASSWORD_HASH=
DASHBOARD_ACCESS_SESSION_DAYS=30

# Codex 日报查询接口凭证（请求头：Authorization: Bearer <token>）
CODEX_REPORT_API_TOKEN=replace-with-a-long-random-token

# 可选：兼容旧命名；如果上面三项已填，可忽略
# LONGPORT_APP_KEY=
# LONGPORT_APP_SECRET=
# LONGPORT_ACCESS_TOKEN=

# OpenAI 摘要，可选
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# AI 市场助手（也可在网页中临时填写，网页不会持久化 API Key）
AI_ASSISTANT_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# AI_ASSISTANT_API_KEY=
# AI_ASSISTANT_MODEL=
# AI_ASSISTANT_BASE_URL=
